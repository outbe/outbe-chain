{
  "name": "@outbe/mcp",
  "version": "0.1.3",
  "description": "Local stdio MCP server for outbe-chain: read chain/precompile state and submit a curated set of signed transactions, with human-decoded output.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "outbe-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/outbe/outbe-chain.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/outbe/outbe-chain/tree/main/mcp",
  "bugs": {
    "url": "https://github.com/outbe/outbe-chain/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "outbe",
    "blockchain",
    "viem"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@noble/ciphers": "1.0.0",
    "@noble/curves": "1.6.0",
    "@noble/hashes": "1.5.0",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
