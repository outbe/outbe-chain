{
  "$id": "https://outbe.io/schemas/release-manifest-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "const": "https://outbe.io/schemas/release-manifest-v1.json"
    },
    "artifacts": {
      "items": {
        "$ref": "#/$defs/artifact"
      },
      "minItems": 1,
      "type": "array"
    },
    "build": {
      "$ref": "#/$defs/build"
    },
    "canonicalization": {
      "$ref": "#/$defs/canonicalization"
    },
    "inputs": {
      "items": {
        "$ref": "#/$defs/material"
      },
      "minItems": 1,
      "type": "array"
    },
    "release": {
      "$ref": "#/$defs/release"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "verification_gates": {
      "items": {
        "$ref": "#/$defs/gate"
      },
      "type": "array"
    }
  },
  "required": [
    "$schema",
    "schema_version",
    "canonicalization",
    "release",
    "build",
    "inputs",
    "artifacts",
    "verification_gates"
  ],
  "title": "Outbe ReleaseManifest v1",
  "type": "object",
  "$defs": {
    "artifact": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "role": {
                "const": "tee-enclave"
              }
            },
            "required": ["role"]
          },
          "then": {
            "required": ["tee"]
          }
        }
      ],
      "properties": {
        "classification": {
          "enum": ["production", "test-only"]
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "features": {
          "items": {
            "$ref": "#/$defs/ascii"
          },
          "type": "array",
          "uniqueItems": true
        },
        "install_profiles": {
          "items": {
            "$ref": "#/$defs/ascii"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "kind": {
          "enum": [
            "elf",
            "archive",
            "native-package",
            "sbom",
            "oci-manifest",
            "compose-descriptor",
            "sgx-rendered-manifest",
            "sgx-sigstruct",
            "gramine-runtime-tree"
          ]
        },
        "media_type": {
          "$ref": "#/$defs/ascii"
        },
        "name": {
          "$ref": "#/$defs/ascii"
        },
        "network_compatibility": {
          "enum": ["network-manifest-required"]
        },
        "package": {
          "$ref": "#/$defs/ascii"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "platform": {
          "$ref": "#/$defs/platform"
        },
        "role": {
          "enum": [
            "node",
            "operator-cli",
            "key-generation",
            "price-feed",
            "tee-enclave",
            "operator-sidecar",
            "installer"
          ]
        },
        "size": {
          "minimum": 0,
          "type": "integer"
        },
        "tee": {
          "$ref": "#/$defs/tee"
        }
      },
      "required": [
        "name",
        "package",
        "kind",
        "role",
        "classification",
        "path",
        "digest",
        "size",
        "media_type",
        "platform",
        "features",
        "install_profiles",
        "network_compatibility"
      ],
      "type": "object"
    },
    "ascii": {
      "minLength": 1,
      "pattern": "^[\\u0020-\\u007e]+$",
      "type": "string"
    },
    "build": {
      "additionalProperties": false,
      "properties": {
        "builder": {
          "$ref": "#/$defs/builder"
        },
        "cargo": {
          "$ref": "#/$defs/cargo"
        },
        "environment": {
          "$ref": "#/$defs/environment"
        },
        "profile": {
          "const": "release"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "rust_toolchain": {
          "const": "1.96.0"
        },
        "source_date_epoch": {
          "minimum": 0,
          "type": "integer"
        },
        "target": {
          "const": "x86_64-unknown-linux-gnu"
        }
      },
      "required": [
        "target",
        "profile",
        "rust_toolchain",
        "source_date_epoch",
        "builder",
        "environment",
        "cargo",
        "provenance"
      ],
      "type": "object"
    },
    "builder": {
      "additionalProperties": false,
      "properties": {
        "debian_snapshot": {
          "pattern": "^[0-9]{8}T[0-9]{6}Z$",
          "type": "string"
        },
        "id": {
          "$ref": "#/$defs/ascii"
        },
        "image": {
          "pattern": "^[^@\\s]+@sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "system_packages": {
          "items": {
            "$ref": "#/$defs/ascii"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "resolved_system_packages": {
          "$ref": "#/$defs/material"
        }
      },
      "required": ["id", "image", "debian_snapshot", "system_packages"],
      "type": "object"
    },
    "canonicalization": {
      "additionalProperties": false,
      "properties": {
        "encoding": {
          "const": "UTF-8"
        },
        "name": {
          "const": "outbe-canonical-json-v1"
        },
        "non_ascii": {
          "const": "lowercase-hex-unicode-escape"
        },
        "object_keys": {
          "const": "unicode-code-point-order"
        },
        "trailing_newline": {
          "const": true
        },
        "whitespace": {
          "const": "none"
        }
      },
      "required": [
        "name",
        "encoding",
        "object_keys",
        "whitespace",
        "non_ascii",
        "trailing_newline"
      ],
      "type": "object"
    },
    "cargo": {
      "additionalProperties": false,
      "properties": {
        "locked": {
          "const": true
        },
        "packages": {
          "items": {
            "$ref": "#/$defs/ascii"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": ["locked", "packages"],
      "type": "object"
    },
    "digest": {
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "const": "sha256"
        },
        "value": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": ["algorithm", "value"],
      "type": "object"
    },
    "environment": {
      "additionalProperties": false,
      "properties": {
        "cflags": {
          "$ref": "#/$defs/ascii"
        },
        "cxxflags": {
          "$ref": "#/$defs/ascii"
        },
        "locale": {
          "const": "C"
        },
        "rustflags": {
          "items": {
            "$ref": "#/$defs/ascii"
          },
          "minItems": 1,
          "type": "array"
        },
        "timezone": {
          "const": "UTC"
        },
        "zero_ar_date": {
          "const": "1"
        }
      },
      "required": ["locale", "timezone", "rustflags", "cflags", "cxxflags", "zero_ar_date"],
      "type": "object"
    },
    "evidence": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "media_type": {
          "$ref": "#/$defs/ascii"
        },
        "uri": {
          "$ref": "#/$defs/ascii"
        }
      },
      "required": ["uri", "media_type", "digest"],
      "type": "object"
    },
    "gate": {
      "additionalProperties": false,
      "properties": {
        "evidence": {
          "items": {
            "$ref": "#/$defs/evidence"
          },
          "type": "array"
        },
        "name": {
          "$ref": "#/$defs/ascii"
        },
        "status": {
          "enum": ["pending", "passed", "failed", "not-applicable"]
        }
      },
      "required": ["name", "status", "evidence"],
      "type": "object"
    },
    "material": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "media_type": {
          "$ref": "#/$defs/ascii"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "size": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": ["path", "digest", "size", "media_type"],
      "type": "object"
    },
    "platform": {
      "additionalProperties": false,
      "properties": {
        "architecture": {
          "const": "x86_64"
        },
        "os": {
          "const": "linux"
        },
        "target": {
          "const": "x86_64-unknown-linux-gnu"
        }
      },
      "required": ["os", "architecture", "target"],
      "type": "object"
    },
    "provenance": {
      "additionalProperties": false,
      "properties": {
        "entrypoint": {
          "const": "scripts/release/reproducible-build.sh"
        },
        "mode": {
          "enum": ["local-container", "github-actions"]
        },
        "workflow": {
          "$ref": "#/$defs/ascii"
        }
      },
      "required": ["mode", "entrypoint"],
      "type": "object"
    },
    "relativePath": {
      "allOf": [
        {
          "$ref": "#/$defs/ascii"
        },
        {
          "not": {
            "pattern": "(^/|(^|/)\\.\\.(/|$))"
          }
        }
      ]
    },
    "release": {
      "additionalProperties": false,
      "properties": {
        "lifecycle": {
          "enum": ["build-candidate", "verified", "revoked"]
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "tag": {
          "$ref": "#/$defs/ascii"
        }
      },
      "required": ["tag", "lifecycle", "source"],
      "type": "object"
    },
    "source": {
      "additionalProperties": false,
      "properties": {
        "clean_tree_policy": {
          "const": "required"
        },
        "commit": {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        "tree_state": {
          "const": "clean"
        }
      },
      "required": ["commit", "clean_tree_policy", "tree_state"],
      "type": "object"
    },
    "tee": {
      "additionalProperties": false,
      "properties": {
        "mock": {
          "const": false
        },
        "stage": {
          "enum": ["unsigned-bare-elf", "rendered", "signed"]
        }
      },
      "required": ["stage", "mock"],
      "type": "object"
    }
  }
}
