# Outbe Reth node configuration
DATADIR=/var/lib/outbe-chain
CHAIN_FILE=/etc/outbe-chain/genesis.json
HTTP_ADDR=127.0.0.1
HTTP_PORT=8545
HTTP_API=eth,net,web3,outbe
P2P_PORT=30303
METRICS_ADDR=0.0.0.0:9001

# Required finalized offchain-data projection (replica set or sharded cluster).
OUTBE_PROJECTION_MONGODB_URI=mongodb://127.0.0.1:27017/?replicaSet=rs0
OUTBE_PROJECTION_MONGODB_DATABASE=outbe_fullnode_0
