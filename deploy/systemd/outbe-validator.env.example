# Outbe Reth validator node configuration
DATADIR=/var/lib/outbe-chain
CHAIN_FILE=/etc/outbe-chain/genesis.json
HTTP_ADDR=127.0.0.1
HTTP_PORT=8545
HTTP_API=eth,net,web3,outbe
P2P_PORT=30303
METRICS_ADDR=0.0.0.0:9001

# Consensus
SIGNING_KEY=/etc/outbe-chain/signing-key.hex
EVM_KEY=/etc/outbe-chain/evm-key.hex
CONSENSUS_ADDR=0.0.0.0:30400
CONSENSUS_STORAGE=/var/lib/outbe-chain/consensus
# validators.json is a genesis/tooling input only; it is not passed to runtime.
