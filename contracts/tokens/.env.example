# Signer used by Forge scripts.
# Keep this secret. Do not commit a real private key.
PRIVATE_KEY=
DEPLOYER_ADDRESS=

# ERC-7786 gateway/hub facade used by local token bridge contracts.
BRIDGE_ADDRESS=0x5cfeca0d28451389F1cdAF1B1167E3c1C5E36bdf

# RPC endpoints.
BSC_RPC=https://data-seed-prebsc-2-s1.bnbchain.org:8545
OUTBE_RPC=https://rpc.testnet.outbe.net/

# ERC-7786 domains. For the prebsc RPC above, BSC_CHAIN_ID must be 97.
# Use 56 only with a BSC mainnet RPC.
BSC_CHAIN_ID=97
OUTBE_CHAIN_ID=54322345

# USDT0 route addresses.
# Fill these after `script/usdt0/USDT0Deploy.s.sol:USDT0Deploy` prints them, or source
# `deployments/usdt0.env` after deployment.
BSC_USDT_TOKEN=
BSC_USDT_BRIDGE=
OUTBE_USDT0_TOKEN=
OUTBE_USDT0_BRIDGE=

# WCOEN route addresses.
# Fill these after `script/wcoen/WCOENDeploy.s.sol:WCOENDeploy` prints them, or source
# `deployments/wcoen.env` after deployment.
OUTBE_WCOEN_TOKEN=
OUTBE_WCOEN_BRIDGE=
BSC_WCOEN_TOKEN=
BSC_WCOEN_BRIDGE=

# Send inputs. Amount is in local decimals:
# USDT/USDT0 = 6 decimals, WCOEN = 18 decimals.
RECIPIENT=
SEND_AMOUNT_LD=
