# Deployment configuration for the intent Router (ERC-7786 composition).
# Tags below are relative to `mise run deploy-all`:
#   [required] — must be set for deploy-all
#   [optional] — has a default, or only needed by individual scripts / configure steps

# [required] Network to deploy on (outbe-priv, outbe-dev, outbe-testnet, bsc-testnet, sepolia)
NETWORK=outbe-testnet
# [required] Deployer private key
DEPLOYER_PK=
# [required] Salt for deterministic (CREATE3) deployment — keep identical across chains for a shared address
CONTRACT_SALT=
# [required] Router admin (owner)
ROUTER_OWNER=
# [required] Cross-chain hub facade (crosschain ERC7786Bridge) the Router sends through
BRIDGE_ADDRESS=
# [required] The Compact
COMPACT_ADDRESS=

# [optional] CreateX factory. deploy-all deploys its own; set this for individual scripts / when reusing an existing one
CREATEX_ADDRESS=
# [optional] Auction. deploy-all deploys it; required only for standalone 3_DeployRouter
AUCTION_ADDRESS=
# [optional] SolverEscrow (empty / address(0) disables collateral)
ESCROW_ADDRESS=
# [optional] RouterAllocator — output of 3_DeployRouter; needed by standalone ConfigureAll
ALLOCATOR_ADDRESS=
# [optional] Deployed Router address — output of 3_DeployRouter; needed by standalone Configure* scripts
ROUTER_ADDRESS=
# [optional] Remote EVM chain ids to register as counterparts, csv (domain == chainId); empty = none wired
REMOTE_CHAIN_IDS=
# [optional] Collateral requirement in basis points (default 1000 = 10%)
COLLATERAL_BPS=1000
