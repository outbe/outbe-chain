# Deployment Configuration for LayerZero7683

# Network to deploy on (outbe-priv,outbe-dev bsc-testnet, sepolia)
NETWORK=outbe-dev

# Deployer private key
DEPLOYER_PK=

# Salt for deterministic deployment
CONTRACT_SALT=
# CreateX address (same on all chains)
CREATEX_ADDRESS=


# Router owner address (who can configure peers)
ROUTER_OWNER=

LZ_ENDPOINT=

# Address of deployed LayerZero7683 contract
ROUTER_ADDRESS=

# Peer endpoint IDs (comma separated)
PEER_EIDS=
# Peer contract addresses (comma separated)
PEER_ADDRESSES=
# Peer domain IDs (comma separated)
PEER_DOMAINS=

COMPACT_ADDRESS=
SOLVER_ESCROW_ADDRESS=

