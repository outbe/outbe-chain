# Common signer.
# `DEPLOYER_PK` is accepted by `script/run-oft.sh` and exported as `PRIVATE_KEY`.
DEPLOYER_PK=
# Optional. If omitted, `script/run-oft.sh` derives it with `cast wallet address`.
DEPLOYER_ADDRESS=

# ERC-7786 gateway/hub facade address on the local chain.
# Current provided value:
BRIDGE_ADDRESS=0x5cfeca0d28451389F1cdAF1B1167E3c1C5E36bdf

# RPCs.
BSC_RPC=
OUTBE_RPC=

# Chain IDs/domains.
BSC_CHAIN_ID=56
OUTBE_CHAIN_ID=

# USDT route: BNB canonical USDT <-> Outbe USDT0 ERC-7802.
# If `BSC_USDT_TOKEN` is empty, `deploySource()` deploys the dev USDT mock.
BSC_USDT_TOKEN=
BSC_USDT_BRIDGE=
OUTBE_USDT0_TOKEN=
OUTBE_USDT0_BRIDGE=

# WCOEN route: Outbe canonical WCOEN <-> BNB WCOEN ERC-7802.
# If `OUTBE_WCOEN_TOKEN` is empty, `deploySource()` deploys WCOEN.
OUTBE_WCOEN_TOKEN=
OUTBE_WCOEN_BRIDGE=
BSC_WCOEN_TOKEN=
BSC_WCOEN_BRIDGE=

# Send inputs. Amount is local decimals: USDT/USDT0 = 6, WCOEN = 18.
RECIPIENT=
SEND_AMOUNT_LD=

# Optional Foundry gas overrides for chains with non-standard fee floors.
# Values are wei. Example priority fee: 100000000 = 0.1 gwei.
FORGE_PRIORITY_GAS_PRICE=
FORGE_WITH_GAS_PRICE=
FORGE_LEGACY=

# Optional token metadata/salts.
TOKEN_NAME=
TOKEN_SYMBOL=
TOKEN_DECIMALS=
TOKEN_CREATE2_SALT=
TOKEN_BRIDGE_CREATE2_SALT=
INITIAL_MINT_AMOUNT=
WCOEN_TOKEN_CREATE2_SALT=
WCOEN_BRIDGE_CREATE2_SALT=
