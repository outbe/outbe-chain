{
  "name": "@outbe/intex-contracts",
  "version": "0.1.0",
  "packageManager": "yarn@4.9.3",
  "type": "module",
  "description": "Outbe Intex smart contracts - ABIs, TypeChain types, and deployment addresses",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./abi/*": "./abi-export/*.json",
    "./addresses/*": "./dist/addresses/*.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Outbe/outbe-intex.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist",
    "abi-export"
  ],
  "scripts": {
    "test:forge": "forge test -vvv",
    "test": "yarn test:forge",
    "lz:wire": "hardhat lz:oapp:wire --oapp-config config/layerzero.config.ts",
    "lz:wire:batch": "hardhat lz:oapp:wire --oapp-config config/layerzero.batch.config.ts",
    "lz:wire:bridge": "hardhat lz:oapp:wire --oapp-config config/layerzero.bridge.config.ts",
    "compile": "hardhat compile",
    "lint": "solhint 'contracts/**/*.sol'",
    "lint:fix": "solhint 'contracts/**/*.sol' --fix --noPrompt",
    "slither": "mise exec -- uvx --from slither-analyzer==0.11.5 slither .",
    "slither:sarif": "mise exec -- uvx --from slither-analyzer==0.11.5 slither . --sarif slither-report.sarif",
    "slither:ci": "mise exec -- uvx --from slither-analyzer==0.11.5 slither . --sarif slither-report.sarif --fail-high",
    "aderyn": "mise exec -- aderyn . --skip-cloc --skip-update-check",
    "analyze": "yarn slither && yarn aderyn",
    "format:check": "forge fmt --check",
    "format:fix": "forge fmt",
    "validate:upgrades": "forge clean && forge build && openzeppelin-upgrades-core validate out/build-info --exclude 'test/**' --unsafeAllow 'constructor,state-variable-immutable,missing-initializer-call,external-library-linking'",
    "coverage:foundry": "forge coverage --ir-minimum --report lcov --report-file lcov.info",
    "fix": "yarn lint:fix && yarn format:fix",
    "cd:extract-abi": "tsx scripts/cd/extract-abi.ts",
    "cd:save-addresses": "tsx scripts/cd/save-addresses.ts",
    "cd:resolve-params": "tsx scripts/cd/resolve-parameters.ts",
    "lz:set-peer": "hardhat lz:set-peer",
    "lz:set-uln-config": "hardhat lz:set-uln-config",
    "lz:set-enforced-options": "hardhat lz:set-enforced-options",
    "lz:grant-bridge-role": "hardhat lz:grant-bridge-role",
    "lz:check-peer": "hardhat lz:check-peer",
    "lz:quote-send": "hardhat lz:quote-send",
    "lz:manual-deliver": "hardhat lz:manual-deliver",
    "lz:clear-stuck-nonces": "hardhat lz:clear-stuck-nonces",
    "auction:interactive": "hardhat auction-interactive",
    "outbe:interactive": "hardhat outbe-interactive",
    "prepublishOnly": "yarn compile && yarn cd:extract-abi"
  },
  "devDependencies": {
    "@layerzerolabs/lz-definitions": "^3.0.148",
    "@layerzerolabs/lz-evm-messagelib-v2": "3.0.148",
    "@layerzerolabs/lz-evm-protocol-v2": "3.0.148",
    "@layerzerolabs/lz-evm-v1-0.7": "^3.0.154",
    "@layerzerolabs/lz-v2-utilities": "^3.0.148",
    "@layerzerolabs/oapp-evm": "patch:@layerzerolabs/oapp-evm@npm%3A0.4.1#~/.yarn/patches/@layerzerolabs-oapp-evm-npm-0.4.1-0a45191000.patch",
    "@layerzerolabs/oapp-evm-upgradeable": "0.1.3",
    "@layerzerolabs/onft-evm": "0.2.4",
    "@layerzerolabs/test-devtools-evm-foundry": "^8.0.1",
    "@layerzerolabs/toolbox-foundry": "^0.1.12",
    "@nomicfoundation/hardhat-ethers": "^4.0.0",
    "@nomicfoundation/hardhat-ignition": "^3.0.0",
    "@nomicfoundation/hardhat-ignition-viem": "^3.0.0",
    "@nomicfoundation/hardhat-keystore": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.0",
    "@nomicfoundation/hardhat-node-test-runner": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.0",
    "@nomicfoundation/hardhat-typechain": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^3.0.0",
    "@nomicfoundation/hardhat-viem": "^3.0.0",
    "@nomicfoundation/hardhat-viem-assertions": "^3.0.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@openzeppelin/contracts-upgradeable": "5.4.0",
    "@openzeppelin/upgrades-core": "1.46.0",
    "@types/node": "^22.17.2",
    "dotenv": "^17.2.2",
    "ethers": "^6.14.0",
    "forge-std": "https://github.com/foundry-rs/forge-std.git#v1.9.4",
    "fp-ts": "^2.16.9",
    "hardhat": "^3.0.0",
    "solhint": "^6.0.1",
    "solidity-bytes-utils": "^0.8.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "~5.8.0",
    "viem": "^2.34.0"
  },
  "resolutions": {
    "ethers": "^6.14.0"
  },
  "dependencies": {
    "@layerzerolabs/metadata-tools": "^3.0.3",
    "@layerzerolabs/toolbox-hardhat": "^0.6.13"
  }
}
