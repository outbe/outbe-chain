# Deployment configuration for the crosschain hub (ERC7786Bridge + gateway adapters).
# Tags are relative to `mise run deploy-all`:
#   [required] — must be set for deploy-all
#   [optional] — has a default, or only needed by configure steps

# [required] Network (outbe-priv, outbe-dev, outbe-testnet, bsc-testnet, sepolia)
NETWORK=outbe-testnet
# [required] Deployer private key
DEPLOYER_PK=
# [required] Salt for deterministic (CREATE3) deployment — keep identical across chains for a shared address
CONTRACT_SALT=
# [required] Bridge + adapters admin (owner)
BRIDGE_OWNER=

# [required: at least one] LayerZero V2 endpoint on this chain — LZ adapter is deployed only if set
LZ_ENDPOINT=
# [required: at least one] Hyperlane Mailbox on this chain — Hyperlane adapter is deployed only if set
HYPERLANE_MAILBOX=

# [optional] CreateX factory; deploy-all deploys its own when unset, set to reuse an existing one
CREATEX_ADDRESS=
# [optional] Active gateway selected on the bridge: "lz" or "hyperlane" (default "lz")
ACTIVE_GATEWAY=lz

# [optional] Remote EVM chain ids to wire, csv — used by configure-bridge
REMOTE_CHAIN_IDS=
# [optional] LayerZero eids parallel to REMOTE_CHAIN_IDS, csv — used by configure-bridge when wiring LZ
REMOTE_EIDS=

# [optional] Wire the local chain as a destination through the loopback adapter (origin==target setups)
WIRE_LOOPBACK=false
